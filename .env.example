# =============================================================================
# Mini CRM - .env.example
# =============================================================================
# Copiá este archivo como .env y completá con tus valores reales.
# El archivo .env NO debe subirse al repo (ya está en .gitignore).
# =============================================================================

# ID del Google Sheet principal (está en la URL del sheet)
GOOGLE_SHEET_ID=

# ID del Google Sheet de backup (uno DISTINTO al principal)
GOOGLE_SHEET_ID_BACKUP=

# Clave secreta de Flask para firmar las sesiones.
# GENERÁ UNA NUEVA con: python -c "import secrets; print(secrets.token_urlsafe(64))"
# NUNCA uses la que viene por default en produccion.
SECRET_KEY=
